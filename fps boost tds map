-- SYSTEM: Logic Kéo Thả (Drag GUI) - Đã sửa lỗi hoàn toàn
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)


-- SYSTEM: Logic Tối Ưu Hóa (Optimize / Restore)
local isOptimized = false

-- Hàm lưu thông số cũ và giảm chất lượng (Optimize)
local function optimizeGame()
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            -- Lưu thuộc tính gốc vào Attribute
            if not v:GetAttribute("OldMaterial") then v:SetAttribute("OldMaterial", v.Material.Name) end
            if not v:GetAttribute("OldTransparency") then v:SetAttribute("OldTransparency", v.Transparency) end
            if not v:GetAttribute("OldColor") then v:SetAttribute("OldColor", v.Color) end
            
            -- Thực hiện tối ưu (giảm lag)
            v.Material = Enum.Material.SmoothPlastic
            v.Transparency = 0.5 -- Bạn có thể tăng lên nếu muốn làm tàng hình bớt vật thể
        elseif v:IsA("MeshPart") then
            if not v:GetAttribute("OldTexture") then v:SetAttribute("OldTexture", v.TextureID) end
            v.TextureID = "" -- Xóa texture của mesh để giảm bộ nhớ đồ họa
        elseif v:IsA("Decal") or v:IsA("Texture") then
            if not v:GetAttribute("OldParent") then
                v:SetAttribute("OldParent", v.Parent.Name)
                v.Parent = nil -- Ẩn decal đi
            end
        end
    end
end

-- Hàm khôi phục lại đồ họa cũ (Restore)
local function restoreGame()
    -- Khôi phục các Decal đã bị ẩn tạm thời
    for _, v in ipairs(game:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then
            local oldParentName = v:GetAttribute("OldParent")
            if oldParentName then
                local realParent = workspace:FindFirstChild(oldParentName, true)
                if realParent then
                    v.Parent = realParent
                end
                v:SetAttribute("OldParent", nil)
            end
        end
    end

    -- Khôi phục các BasePart & MeshPart
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local oldMat = v:GetAttribute("OldMaterial")
            local oldTrans = v:GetAttribute("OldTransparency")
            local oldColor = v:GetAttribute("OldColor")
            
            if oldMat then v.Material = Enum.Material[oldMat] end
            if oldTrans then v.Transparency = oldTrans end
            if oldColor then v.Color = oldColor end
            
            v:SetAttribute("OldMaterial", nil)
            v:SetAttribute("OldTransparency", nil)
            v:SetAttribute("OldColor", nil)
        end
        
        if v:IsA("MeshPart") then
            local oldTex = v:GetAttribute("OldTexture")
            if oldTex then v.TextureID = oldTex end
            v:SetAttribute("OldTexture", nil)
        end
    end
end

-- Sự kiện nhấn nút kích hoạt
textButton.MouseButton1Click:Connect(function()
    isOptimized = not isOptimized
    
    if isOptimized then
        -- Chuyển trạng thái sang Đã tối ưu
        textButton.Text = "DEACTIVATE"
        textButton.BackgroundColor3 = Color3.fromRGB(116, 0, 143) -- Màu tím đỏ
        optimizeGame()
    else
        -- Trở lại bình thường
        textButton.Text = "ACTIVATE"
        textButton.BackgroundColor3 = Color3.fromRGB(51, 0, 112) -- Màu tím gốc
        restoreGame()
    end
end)
